mode: momentum_pyramid

# ── ORACLE WEIGHTS ─────────────────────────────────────────────────────────
ofi_alpha:            0.4
ofi_q0_influence:     1.2
velocity_alpha:       0.3
basis_alpha:          0.2
w_delta:              0.4
w_ofi:                1.5
w_basis:              0.4
w_velocity:           1.5
score_norm_factor:    40.0
w_kalshi_vel:         0.0
ofi_normalizer:       50.0

# ── SIGNAL THRESHOLDS ──────────────────────────────────────────────────────
# AFTER-HOURS: Dropped back to 0.18. In low-volume regimes, we don't get massive 
# momentum spikes. We need to let the bot trigger slightly earlier on quieter tape.
spike_threshold_tier1: 0.18  
spike_threshold_tier2: 0.45
spike_threshold_tier3: 0.70

# ── V4 CONVICTION ENGINE ───────────────────────────────────────────────────
# AFTER-HOURS: Dropped from 1.5 to 0.8. The night tape is thin; we can't demand morning volume.
min_binance_volume:  0.05 
# AFTER-HOURS: Dropped from 0.25 to 0.10. Net flow just needs to tilt in our direction.
min_cvd_alignment:   0.01   
# AFTER-HOURS: Dropped from 1.5 to 0.8. BTC moves slower at night. We still check the anchor 
# to avoid fighting a trend, but we don't demand a massive dollar move.
min_btc_delta:       0.1    
min_liquidity_ratio: 1.2    

reversal_threshold:    0.25  
bad_odds_tier1_cents:  80      
min_entry_price_cents: 30.0    
momentum_deriv_floor: 0.0025

# ── PYRAMID ────────────────────────────────────────────────────────────────
pyramid_levels: [5, 3, 1]      
avg_cost_guard_pct:   2.0

# ── EXIT MODE ──────────────────────────────────────────────────────────────
exit_mode:            full_dump
quick_profit_cents:   12.0     
scale_tier1_cents:    4.0
scale_tier2_cents:    8.0
runner_trailing_stop_cents: 2.0
ioc_timeout_secs:     3        

# ── IRONCLAD RISK HIERARCHY ────────────────────────────────────────────────
guillotine_velocity_threshold:  10.0    
guillotine_gap_cents:           8.0
spread_blown_threshold_cents:   10.0
hard_stop_naked_cents:          14.0    
cushion_guard_min_pnl_cents:   -999.0   
basis_dislocation_threshold:    8.0
vault_drawdown_cents:          -2000.0  
daily_target_cents:             5000.0
trailing_ratchet_pct:           0.50    
ws_blackout_seconds:            30
god_candle_max_spread_cents:    6.0     
entry_velocity_max:             5.0

# ── THRESHOLD ADJUSTMENT CAP ──────────────────────────────────────────────
# Caps the time-decay multiplier so late-cycle entries aren't choked out
max_total_adj: 1.3

# ── INFRA ──────────────────────────────────────────────────────────────────
scan_interval_ms:     200
jsonl_path:           wolf_flight.jsonl
pnl_path:             pnl_tracker_eth.txt